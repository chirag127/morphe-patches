# ── Device configuration ─────────────────────────────────────────────
# Copy this file to device.env and fill in your device's values:
#
#   cp testing/config/device.env.example testing/config/device.env
#
# device.env is gitignored, so your device details never leave your machine.

# IP address of your Onn TV box (Settings → Network & Internet to find it).
# Tip: set a DHCP reservation on your router so it doesn't change.
DEVICE_IP="192.168.1.100"

# ADB TCP port. 5555 is the classic "adb tcpip" port. If you use
# Android 11+ Wireless Debugging pairing, put the port it shows here.
DEVICE_PORT="5555"

# Optional: full ADB serial to target instead of IP:PORT (e.g. a USB
# device). Leave empty to use DEVICE_IP:DEVICE_PORT.
DEVICE_SERIAL=""
